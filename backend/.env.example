PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/digital_verif_system?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_change_in_production
GITHUB_TOKEN=your_github_personal_access_token
FRONTEND_URL=http://localhost:3000

# Daily stats refresh schedule (cron format, default = 2:00 AM daily)
REFRESH_CRON=0 2 * * *
# Timezone for the cron schedule (default = Asia/Kolkata)
REFRESH_TIMEZONE=Asia/Kolkata
